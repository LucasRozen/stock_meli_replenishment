<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_meli_replenishment" model="ir.cron">
            <field name="name">MELI: Verificar y reponer stock desde R/S</field>
            <field name="model_id" ref="model_meli_replenishment_rule"/>
            <field name="state">code</field>
            <field name="code">model._run_replenishment_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>
        <record id="cron_meli_validate_pending" model="ir.cron">
            <field name="name">MELI: Validar reabastecimientos pendientes</field>
            <field name="model_id" ref="model_meli_replenishment_rule"/>
            <field name="state">code</field>
            <field name="code">model.validate_pending_replenishments()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">15</field>
        </record>
    </data>
</odoo>
